  ḋcomponent (-100,800) 0 0
    ḋsymbol HBdriver
      ḋtype: XṠ
      ḋdescription: Machine generated symbol for HBDRIVERṠ
      ḋlibrary file: |.subckt HBdriver s sd +gt -gt +gb -gb\nċ1 N01 0 out ċ N02 sf N01 ċ ċ ċ ċ ċ ċ ċ ċ ċ ulator space=fmin mark=fmax\nV1 N01 0 2\nV3 N02 0 1\nB1 fm 0 V=V(out)-1\nR1 s 0 10Meg\nB2 sf 0 V=if(V(s)>=0, if(V(s)<=1, V(s), 1), 0)\nB3 sq 0 V=if(V(rfm)>pi*dt, 1, 0)\nB4 +gt -gt V=if( V(sd)<0.1, if(V(fm)>0, Vcc*V(sq), 0), 0)\nB5 +gb -gb V=if( V(sd)<0.1, if(V(fm)<0, Vcc*V(sq), 0), 0 )\nB6 rfm 0 V=abs(V(fm))\nR2 sd 0 10Meg\n.ends HBdriverṠ
      ḋshorted pins: falseṠ
      ḋrect (-800,-700) (800,700) 0 0 0 0xff0000 0x4000000 -1 0 -1Ṡ
      ḋtext (0,200) 1 15 0 0x1000000 -1 -1 "X1"Ṡ
      ḋtext (0,0) 1 15 0 0x1000000 -1 -1 "HBDRIVER"Ṡ
      ḋtext (-550,-1000) 1 0 0 0x0 -1 -1 "fmin=1"Ṡ
      ḋtext (-400,-1200) 1 0 0 0x0 -1 -1 "fmax=100K"Ṡ
      ḋtext (-550,-800) 1 0 0 0x0 -1 -1 "Vcc=15"Ṡ
      ḋtext (-500,-1400) 1 0 0 0x0 -1 -1 "dt=0.02"Ṡ
      ḋpin (-800,300) (60,20) 1 7 0 0x0 -1 "s"Ṡ
